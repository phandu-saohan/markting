# Normalize line endings to LF for all text files
* text=auto eol=lf

# Force LF for these file types
*.ts    text eol=lf
*.js    text eol=lf
*.json  text eol=lf
*.yaml  text eol=lf
*.yml   text eol=lf
*.md    text eol=lf
*.sql   text eol=lf
*.sh    text eol=lf

# Binary files
*.png   binary
*.jpg   binary
*.jpeg  binary
*.gif   binary
*.ico   binary
*.zip   binary
