# ─── APP ──────────────────────────────────────────
NODE_ENV=development
PORT=3000
JWT_SECRET=change-me-in-production
ENCRYPTION_KEY=32-char-secret-key-for-aes256!

# ─── DATABASE ─────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=marketing_db
DB_USER=postgres
DB_PASS=postgres

# ─── REDIS ────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ─── FACEBOOK ─────────────────────────────────────
FB_APP_ID=your_facebook_app_id
FB_APP_SECRET=your_facebook_app_secret
FB_GRAPH_API_VERSION=v19.0

# ─── ZALO OA ──────────────────────────────────────
ZALO_OA_APP_ID=your_zalo_oa_app_id
ZALO_OA_SECRET=your_zalo_oa_app_secret

# ─── TIKTOK ───────────────────────────────────────
TIKTOK_CLIENT_KEY=your_tiktok_client_key
TIKTOK_CLIENT_SECRET=your_tiktok_client_secret

# ─── YOUTUBE ──────────────────────────────────────
YOUTUBE_CLIENT_ID=your_google_client_id
YOUTUBE_CLIENT_SECRET=your_google_client_secret

# ─── EMAIL ────────────────────────────────────────
# Chọn một trong hai: ses hoặc sendgrid
EMAIL_PROVIDER=ses

# Amazon SES
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your_aws_key
AWS_SECRET_ACCESS_KEY=your_aws_secret
SES_FROM_EMAIL=noreply@yourdomain.com

# SendGrid (thay thế SES)
SENDGRID_API_KEY=SG.your_sendgrid_api_key
SENDGRID_FROM_EMAIL=noreply@yourdomain.com

# ─── STORAGE ──────────────────────────────────────
S3_BUCKET=marketing-media
S3_REGION=us-east-1
CDN_BASE_URL=https://cdn.yourdomain.com

# ─── PUPPETEER ────────────────────────────────────
CHROME_EXECUTABLE_PATH=/usr/bin/google-chrome
HEADLESS=true
